# SQLite in dev. For prod, point at Postgres and swap the driver adapter in src/server/db.ts.
DATABASE_URL="file:./prisma/dev.db"

# Admin basic-auth credentials (used from milestone 6).
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me"

# Secret for signing anonymous session cookies (used from milestone 4).
SESSION_SECRET="change-me-to-a-long-random-string"
